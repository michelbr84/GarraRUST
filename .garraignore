# .garraignore — regras de exclusão para o scanner de arquivos do agente GarraIA
# Sintaxe idêntica ao .gitignore, com suporte a extglob (!(pat), *(pat), +(pat), @(pat), ?(pat))
# Afeta apenas a varredura do agente (file_read, repo_search, list_dir), NÃO o git.

# ─── Build / artefatos gerados ─────────────────────────────────────────────
target/
dist/
release/
*.wasm

# ─── Dependências e lock files ──────────────────────────────────────────────
# Cargo.lock é grande e gerado automaticamente; não útil para análise do agente
Cargo.lock

# ─── Dados de runtime ───────────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ─── Segredos e credenciais ─────────────────────────────────────────────────
.env
.env.*
credentials/
vault.json

# ─── Scripts de automação temporários (Linear, CI) ──────────────────────────
# Úteis para humanos mas ruidosos para o agente durante buscas de código
*.ps1

# ─── Arquivos de sessão do agente (Claude Code) ─────────────────────────────
# Sessões, audit e config local são ruidosos — ignorados pelo scanner
.claude/sessions/
.claude/audit.log
.claude/settings.local.json
.claude/settings.local.json.bak
.claude/team-output/
# hooks/, agents/, settings.json e skills/ são código do projeto — visíveis ao agente

# ─── GarraDream state (auto-gerado) ────────────────────────────────────────
.dream-state.json
.dream.lock

# ─── Workflow outputs ──────────────────────────────────────────────────────
batch-results.json
parallel-review-*.md

# ─── Voice / áudio temporário ───────────────────────────────────────────────
voice_temp/
*.input.ogg
*.output.ogg

# ─── Python (serviços de voz) ───────────────────────────────────────────────
__pycache__/
*.pyc
venv/
.venv/

# ─── Testes externos / fixtures grandes ─────────────────────────────────────
testsprite_tests/
.testsprite/

# ─── Documentação compilada ─────────────────────────────────────────────────
book/
docs/book/

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Planejamento interno ───────────────────────────────────────────────────
plans/

# ─── Flutter / garraia-mobile ───────────────────────────────────────────────
# Build e artefatos gerados — não têm valor para análise de código-fonte
apps/garraia-mobile/build/
apps/garraia-mobile/.dart_tool/
apps/garraia-mobile/android/.gradle/
# Código gerado pelo build_runner — derivado das fontes reais
apps/garraia-mobile/**/*.g.dart
apps/garraia-mobile/**/*.freezed.dart
# Metadados locais do Flutter
apps/garraia-mobile/android/local.properties
apps/garraia-mobile/android/key.properties
apps/garraia-mobile/.flutter-plugins
apps/garraia-mobile/.flutter-plugins-dependencies

# ─── Tauri / garraia-desktop ────────────────────────────────────────────────
# Artefatos gerados pelo Tauri build — não são código-fonte útil para o agente
crates/garraia-desktop/src-tauri/gen/
crates/garraia-desktop/src-tauri/target/
crates/garraia-desktop/src-tauri/WixTools/
crates/garraia-desktop/node_modules/
# Sprite sheet PNG — binário gerado, não tem valor de busca textual
crates/garraia-desktop/ui/assets/parrot-sprite.png

# ─── OS / IDE ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
