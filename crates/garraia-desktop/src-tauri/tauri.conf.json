{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "garraia-desktop",
  "version": "0.2.0",
  "identifier": "org.garraia.desktop",
  "build": {
    "frontendDist": "../ui",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/michelbr84/GarraRUST/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/garra"],
    "resources": ["resources/config.default.yml"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      }
    }
  }
}
