# GarraIA Configuration Example
# Copy to .env and fill in your values.
# Referenced by docker-compose.yml.

# --- LLM Provider API Keys (at least one required) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# MISTRAL_API_KEY=your_mistral_key_here
# GEMINI_API_KEY=your_gemini_key_here
# COHERE_API_KEY=your_cohere_key_here
# SANSA_API_KEY=your_sansa_key_here

# --- Web Search ---
# BRAVE_API_KEY=your_brave_search_key_here

# --- Auth (JWT + refresh + mobile) ---
# Plan 0046 (GAR-379 slice 3): secrets are ENV-ONLY. The config file
# never accepts them. When both env vars below are absent, /auth/* and
# /v1/auth/* respond 503 "auth not configured" (fail-closed).
#
# Preferred canonical name for the HS256 JWT signing secret (≥32 bytes):
GARRAIA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
#
# Legacy fallback: accepted by AuthConfig::from_env() when
# GARRAIA_JWT_SECRET is absent. Kept for zero-breaking-change in dev
# workflows that predate GAR-379. New deployments SHOULD prefer
# GARRAIA_JWT_SECRET. If both are set, GARRAIA_JWT_SECRET wins.
# GarraIA_VAULT_PASSPHRASE=change-me-generate-with-openssl-rand-hex-32
#
# Personalidade PT-BR do Garra no chat mobile (opcional — tem default embutido)
# GARRA_MOBILE_PERSONA=Você é o Garra...

# --- Vault Encryption ---
# REQUIRED to encrypt MCP tokens and API keys at rest (AES-256-GCM).
# Without this, sensitive values are saved as plaintext in mcp.json.
# Generate a strong passphrase with: openssl rand -hex 32
#
# NOTE (plan 0046): case-sensitive. `GarraIA_VAULT_PASSPHRASE` (mixed
# case) is the legacy alias also accepted by `AuthConfig::from_env` as
# a fallback for `GARRAIA_JWT_SECRET`. Keep the spelling below for
# `garraia-security::CredentialVault` ingest.
GARRAIA_VAULT_PASSPHRASE=change-me-generate-with-openssl-rand-hex-32

# --- Channel Tokens (optional) ---
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# DISCORD_APP_ID=your_discord_app_id_here
# SLACK_BOT_TOKEN=your_slack_bot_token_here
# SLACK_APP_TOKEN=your_slack_app_token_here
# WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
# WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# --- Gateway Configuration (optional) ---
# GarraIA_GATEWAY_PORT=3888
# GarraIA_GATEWAY_HOST=0.0.0.0
# GARRAIA_API_KEY=your_gateway_bearer_token_here
# GARRAIA_CONFIG_DIR=/custom/config/path

# --- Gateway port override ---
# GARRAIA_PORT=3888

# --- OpenClaw Bridge (optional — multi-channel AI assistant) ---
# Install: npm install -g openclaw@latest
# OPENCLAW_ENABLED=false
# OPENCLAW_WS_URL=ws://127.0.0.1:18789
# OPENCLAW_TOOL_SHARING=false
# OPENCLAW_VOICE_BRIDGE=false

# --- Voice (TTS / STT) ---
# Provider: "chatterbox", "hibiki", or "lmstudio"
# GARRAIA_TTS_PROVIDER=lmstudio
# GARRAIA_TTS_MODEL=vieneu-tts-v2-turbo
# GARRAIA_TTS_ENDPOINT=http://127.0.0.1:1234
# GARRAIA_STT_ENDPOINT=http://127.0.0.1:1234
# GARRAIA_VOICE_LANGUAGE=pt

# --- Embeddings (LM Studio / OpenAI-compatible) ---
# GARRAIA_EMBEDDING_PROVIDER=lmstudio
# GARRAIA_EMBEDDING_MODEL=text-embedding-mxbai-embed-large-v1
# GARRAIA_EMBEDDING_BASE_URL=http://localhost:1234
# GARRAIA_EMBEDDING_API_KEY=lm-studio

# --- Database (GAR-302: optional Postgres via docker-compose.postgres.yml) ---
# DATABASE_URL=postgres://garraia:password@localhost:5432/garraia
# POSTGRES_PASSWORD=garraia

# =====================================================================
# Variáveis abaixo são placeholder para o ROADMAP AAA (Fases 2-3).
# Ainda NÃO são lidas pelo gateway — mantenha comentadas até as fases
# correspondentes esquentarem. Ver ROADMAP.md e issues GAR-371..410.
# =====================================================================

# --- Group Workspace (Fase 3 — Postgres multi-tenant, GAR-407) ---
# Postgres com pgvector usado pelo crate garraia-workspace.
# GARRAIA_WORKSPACE_DATABASE_URL=postgres://garraia:password@localhost:5432/garraia_workspace
# GARRAIA_WORKSPACE_MAX_CONNECTIONS=20
# GARRAIA_WORKSPACE_MIGRATE_ON_START=true

# --- Object Storage (Fase 3.5 — GAR-394, garraia-storage) ---
# Backend: "local" | "s3" | "none"
# GARRAIA_STORAGE_BACKEND=local
# GARRAIA_STORAGE_LOCAL_PATH=./data/storage
# GARRAIA_STORAGE_S3_ENDPOINT=http://localhost:9000
# GARRAIA_STORAGE_S3_BUCKET=garraia
# GARRAIA_STORAGE_S3_ACCESS_KEY=minioadmin
# GARRAIA_STORAGE_S3_SECRET_KEY=minioadmin
# GARRAIA_STORAGE_S3_REGION=us-east-1
# GARRAIA_STORAGE_S3_PRESIGN_TTL_SECONDS=900
# Plan 0044 (GAR-395 slice 2): HMAC secret (≥32 bytes) used to sign
# `file_versions.integrity_hmac` on every tus commit. Fail-closed —
# without this var the PATCH handler answers 503. Generate with
# `openssl rand -hex 32`.
# GARRAIA_UPLOAD_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Auth v1 (GAR-391c — garraia-auth wired into AppState) ---
# All four vars below are required for /v1/auth/{login,refresh,logout,signup}
# to be enabled. If ANY is missing, the gateway boots in fail-soft mode and
# the auth endpoints return 503 (no error on startup, just a warning log).
# JWT signing secret (HS256, ≥32 bytes). Same env var as legacy mobile_auth.
# GARRAIA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# HMAC-SHA256 secret for refresh-token hashing. MUST be distinct from
# GARRAIA_JWT_SECRET. Generate with `openssl rand -hex 32`.
# GARRAIA_REFRESH_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32
# Postgres URL connecting as the `garraia_login` BYPASSRLS role
# (created by migration 008). Used by LoginPool for credential verification,
# session issuance, refresh, and group_members membership lookups.
# GARRAIA_LOGIN_DATABASE_URL=postgres://garraia_login:password@localhost:5432/garraia_workspace
# Postgres URL connecting as the `garraia_signup` BYPASSRLS role
# (created by migration 010). Used by SignupPool exclusively for the
# /v1/auth/signup endpoint. NEVER reuse the login pool credentials here.
# GARRAIA_SIGNUP_DATABASE_URL=postgres://garraia_signup:password@localhost:5432/garraia_workspace

# --- Identity / Auth (Future — OIDC, post-391c) ---
# OIDC adapters land in a future ADR (0009). The vars below are placeholders
# only; they have no effect in the current build.
# GARRAIA_AUTH_PROVIDER=internal
# GARRAIA_OIDC_ISSUER=https://keycloak.example/realms/garraia
# GARRAIA_OIDC_CLIENT_ID=garraia
# GARRAIA_OIDC_CLIENT_SECRET=change-me

# --- Observabilidade (Fase 2.3 — GAR-384, garraia-telemetry) ---
# OpenTelemetry OTLP exporter (Jaeger, Tempo, Honeycomb, Grafana Cloud, etc.)
# GARRAIA_OTEL_ENABLED=false
# GARRAIA_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# GARRAIA_OTEL_SERVICE_NAME=garraia-gateway
# GARRAIA_OTEL_SAMPLE_RATIO=1.0
# Prometheus metrics endpoint (exposto em /metrics quando habilitado)
# GARRAIA_METRICS_ENABLED=false
# Bind address do exporter Prometheus. Default 127.0.0.1 (loopback-only) por
# segurança. Mudar para 0.0.0.0 exige Bearer token ou CIDR allowlist (plan
# 0024 / GAR-412) — senão o listener dedicado fica fail-closed no startup e
# a rota embedded responde 503 para peers não-loopback.
# GARRAIA_METRICS_BIND=127.0.0.1:9464
# Bearer token para /metrics. Redacted em logs; comparação constant-time.
# GARRAIA_METRICS_TOKEN=<random-hex>
# Comma-separated CIDR allowlist para /metrics. Aceita IP único, /32, /128.
# GARRAIA_METRICS_ALLOW=127.0.0.1/32,10.0.0.0/8

# --- RAG / Memória de longo prazo (Fase 2.1 — GAR-372, garraia-embeddings) ---
# Store: "lancedb" | "qdrant"
# GARRAIA_VECTOR_STORE=lancedb
# GARRAIA_VECTOR_STORE_PATH=./data/vectors
# GARRAIA_EMBEDDINGS_MODEL=mxbai-embed-large-v1
# GARRAIA_EMBEDDINGS_DEVICE=auto  # auto | cpu | cuda | mps
